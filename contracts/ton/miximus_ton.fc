;; =========================================================================
;;                       LEVEL IVs FOR MERKLE TREE
;; =========================================================================
;; 29 level-specific IVs matching the ethsnarks circuit.

int get_level_iv(int level) inline {
    if (level == 0)  { return 149674538925118052205057075966660054952481571156186698930522557832224430770; }
    if (level == 1)  { return 9670701465464311903249220692483401938888498641874948577387207195814981706974; }
    if (level == 2)  { return 18318710344500308168304415114839554107298291987930233567781901093928276468271; }
    if (level == 3)  { return 6597209388525824933845812104623007130464197923269180086306970975123437805179; }
    if (level == 4)  { return 21720956803147356712695575768577036859892220417043839172295094119877855004262; }
    if (level == 5)  { return 10330261616520855230513677034606076056972336573153777401182178891807369896722; }
    if (level == 6)  { return 17466547730316258748333298168566143799241073466140136663575045164199607937939; }
    if (level == 7)  { return 18881017304615283094648494495339883533502299318365959655029893746755475886610; }
    if (level == 8)  { return 21580915712563378725413940003372103925756594604076607277692074507345076595494; }
    if (level == 9)  { return 12316305934357579015754723412431647910012873427291630993042374701002287130550; }
    if (level == 10) { return 18905410889238873726515380969411495891004493295170115920825550288019118582494; }
    if (level == 11) { return 12819107342879320352602391015489840916114959026915005817918724958237245903353; }
    if (level == 12) { return 8245796392944118634696709403074300923517437202166861682117022548371601758802; }
    if (level == 13) { return 16953062784314687781686527153155644849196472783922227794465158787843281909585; }
    if (level == 14) { return 19346880451250915556764413197424554385509847473349107460608536657852472800734; }
    if (level == 15) { return 14486794857958402714787584825989957493343996287314210390323617462452254101347; }
    if (level == 16) { return 11127491343750635061768291849689189917973916562037173191089384809465548650641; }
    if (level == 17) { return 12217916643258751952878742936579902345100885664187835381214622522318889050675; }
    if (level == 18) { return 722025110834410790007814375535296040832778338853544117497481480537806506496; }
    if (level == 19) { return 15115624438829798766134408951193645901537753720219896384705782209102859383951; }
    if (level == 20) { return 11495230981884427516908372448237146604382590904456048258839160861769955046544; }
    if (level == 21) { return 16867999085723044773810250829569850875786210932876177117428755424200948460050; }
    if (level == 22) { return 1884116508014449609846749684134533293456072152192763829918284704109129550542; }
    if (level == 23) { return 14643335163846663204197941112945447472862168442334003800621296569318670799451; }
    if (level == 24) { return 1933387276732345916104540506251808516402995586485132246682941535467305930334; }
    if (level == 25) { return 7286414555941977227951257572976885370489143210539802284740420664558593616067; }
    if (level == 26) { return 16932161189449419608528042274282099409408565503929504242784173714823499212410; }
    if (level == 27) { return 16562533130736679030886586765487416082772837813468081467237161865787494093536; }
    if (level == 28) { return 6037428193077828806710267464232314380014232668931818917272972397574634037180; }
    throw(400); ;; Invalid level
    return 0;
}

;; =========================================================================
;;                         MiMC IMPLEMENTATION
;; =========================================================================
;; MiMC-p/p cipher with x^7 exponent, 91 rounds.
;; Uses TVM native 256-bit (and larger) integer arithmetic.

;; Modular addition: (a + b) mod SCALAR_FIELD
int addmod(int a, int b) inline {
    return (a + b) % SCALAR_FIELD;
}

;; Modular multiplication: (a * b) mod SCALAR_FIELD
int mulmod(int a, int b) inline {
    return (a * b) % SCALAR_FIELD;
}

;; MiMC cipher: E_k(x) with x^7 exponent and 91 rounds
;; Round: t = x + c_i + k; x = t^7
;; Final: result = x + k
int mimc_cipher(int x, int k) inline {
    tuple constants = get_mimc_round_constants();
    int i = 0;
    repeat (MIMC_ROUNDS) {
        int c = constants.at(i);
        int t = addmod(addmod(x, c), k);
        ;; t^7 = t * (t^2)^3
        int t2 = mulmod(t, t);
        int t4 = mulmod(t2, t2);
        int t6 = mulmod(t4, t2);
        x = mulmod(t6, t);
        i += 1;
    }
    ;; Final key addition
    return addmod(x, k);
}

;; MiMC hash with Miyaguchi-Preneel compression and custom IV
;; h = E_k(x) + x + k, where k = running state
int mimc_hash_iv(int val1, int val2, int iv) inline {
    ;; First element
    int h = mimc_cipher(val1, iv);
    int r = addmod(addmod(iv, val1), h);
    ;; Second element
    h = mimc_cipher(val2, r);
    r = addmod(addmod(r, val2), h);
    return r;
}

;; MiMC hash with IV=0 for general hashing (e.g., public inputs)
int mimc_hash(int val1, int val2) inline {
    return mimc_hash_iv(val1, val2, 0);
}

;; MiMC hash of three values (for public input hashing)
int mimc_hash3(int val1, int val2, int val3) inline {
    int h = mimc_cipher(val1, 0);
    int r = addmod(addmod(0, val1), h);
    h = mimc_cipher(val2, r);
    r = addmod(addmod(r, val2), h);
    h = mimc_cipher(val3, r);
    r = addmod(addmod(r, val3), h);
    return r;
}

;; Hash two children at a given Merkle tree level
int merkle_hash(int level, int left, int right) inline {
    int iv = get_level_iv(level);
    return mimc_hash_iv(left, right, iv);
}

;; =========================================================================
;;                          STORAGE LAYOUT
;; =========================================================================
;; Storage cell structure:
;;   - denomination: uint256
;;   - next_leaf_index: uint64
;;   - current_root: uint256
;;   - owner: MsgAddress
;;   - oracle: MsgAddress (trusted proof verifier)
;;   - nullifiers_dict: HashmapE 256 Bool
;;   - roots_dict: HashmapE 256 Bool
;;   - vk_data: Cell (reference)
;;   - tree_nodes: Cell (reference to dict: key=(level<<32|index), val=hash)
;;   - attestations: Cell (reference to dict of pending attestations)

(int, int, int, slice, slice, cell, cell, cell, cell, cell) load_data() inline {
    slice ds = get_data().begin_parse();
    return (
        ds~load_uint(256),      ;; denomination (nanoton)
        ds~load_uint(64),       ;; next_leaf_index
        ds~load_uint(256),      ;; current_root
        ds~load_msg_addr(),     ;; owner
        ds~load_msg_addr(),     ;; oracle address
        ds~load_dict(),         ;; nullifiers
        ds~load_dict(),         ;; roots
        ds~load_ref(),          ;; vk_data
        ds~load_ref(),          ;; tree_nodes (dict: compound_key -> hash_value)
        ds~load_ref()           ;; attestations (dict: pub_hash -> bool)
    );
}

() save_data(int denomination, int next_leaf_index, int current_root,
             slice owner, slice oracle, cell nullifiers, cell roots,
             cell vk_data, cell tree_nodes, cell attestations) impure inline {
    set_data(begin_cell()
        .store_uint(denomination, 256)
        .store_uint(next_leaf_index, 64)
        .store_uint(current_root, 256)
        .store_slice(owner)
        .store_slice(oracle)
        .store_dict(nullifiers)
        .store_dict(roots)
        .store_ref(vk_data)
        .store_ref(tree_nodes)
        .store_ref(attestations)
    .end_cell());
}

;; =========================================================================
;;                     MERKLE TREE (FULL NODE STORAGE)
;; =========================================================================
;; Tree nodes stored in dict with compound key: (level << 32) | index
;; This gives full-node storage instead of just filled subtrees.

;; Compute compound key for tree node storage
int tree_node_key(int level, int index) inline {
    return (level << 32) | index;
}

;; Get node from tree, returns zero hash for level if not found
int get_tree_node(cell tree_nodes, int level, int index) inline {
    int key = tree_node_key(level, index);
    (slice val, int found) = tree_nodes.udict_get?(256, key);
    if (found) {
        return val~load_uint(256);
    }
    ;; Return zero hash (uninitialized node = 0 for level 0)
    ;; For higher levels, the zero hash would be mimc_hash(zero, zero, iv)
    ;; but since we store all computed nodes, returning 0 is safe for leaves
    return 0;
}

;; Set node in tree
cell set_tree_node(cell tree_nodes, int level, int index, int value) inline {
    int key = tree_node_key(level, index);
    tree_nodes~udict_set(256, key,
        begin_cell().store_uint(value, 256).end_cell().begin_parse());
    return tree_nodes;
}

;; Insert leaf and recompute path to root. Returns (new_root, updated_tree_nodes).
(int, cell) insert_leaf(cell tree_nodes, int leaf_hash, int leaf_index) inline {
    ;; Store leaf at level 0
    tree_nodes = set_tree_node(tree_nodes, 0, leaf_index, leaf_hash);
    int current = leaf_hash;
    int idx = leaf_index;

    int level = 0;
    repeat (TREE_DEPTH) {
        int parent_idx = idx / 2;
        int left = 0;
        int right = 0;

        if (idx % 2 == 0) {
            left = current;
            right = get_tree_node(tree_nodes, level, idx + 1);
        } else {
            left = get_tree_node(tree_nodes, level, idx - 1);
            right = current;
        }

        current = merkle_hash(level, left, right);
        tree_nodes = set_tree_node(tree_nodes, level + 1, parent_idx, current);
        idx = parent_idx;
        level += 1;
    }

    return (current, tree_nodes);
}

;; =========================================================================
;;                        INTERNAL RECEIVE
;; =========================================================================

() recv_internal(int my_balance, int msg_value, cell in_msg_full, slice in_msg_body) impure {
    if (in_msg_body.slice_empty?()) {
        return (); ;; Accept empty messages (top-up)
    }

    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);
    if (flags & 1) { ;; bounced
        return ();
    }
    slice sender = cs~load_msg_addr();

    int op = in_msg_body~load_uint(32);
    int query_id = in_msg_body~load_uint(64);

    (int denomination, int next_leaf_index, int current_root,
     slice owner, slice oracle, cell nullifiers, cell roots,
     cell vk_data, cell tree_nodes, cell attestations) = load_data();

    if (op == op::deposit) {
        ;; ============= DEPOSIT =============
        throw_unless(100, msg_value >= denomination);
        throw_unless(101, next_leaf_index < MAX_LEAVES);

        int leaf_hash = in_msg_body~load_uint(256);

        ;; Insert leaf into full-node Merkle tree using MiMC
        (int new_root, cell new_tree_nodes) = insert_leaf(tree_nodes, leaf_hash, next_leaf_index);

        ;; Update roots dictionary
        roots~udict_set(256, new_root,
            begin_cell().store_uint(1, 1).end_cell().begin_parse());

        ;; Save updated state
        save_data(denomination, next_leaf_index + 1, new_root,
                  owner, oracle, nullifiers, roots, vk_data, new_tree_nodes, attestations);

        return ();
    }

    if (op == op::batch_deposit) {
        ;; ============= BATCH DEPOSIT =============
        int count = in_msg_body~load_uint(8);
        throw_unless(103, count > 0);
        throw_unless(104, count <= 20);
        throw_unless(100, msg_value >= denomination * count);
        throw_unless(101, next_leaf_index + count <= MAX_LEAVES);

        int i = 0;
        while (i < count) {
            int leaf_hash = in_msg_body~load_uint(256);

            (int new_root, cell new_tree_nodes) = insert_leaf(tree_nodes, leaf_hash, next_leaf_index);
            tree_nodes = new_tree_nodes;

            roots~udict_set(256, new_root,
                begin_cell().store_uint(1, 1).end_cell().begin_parse());

            next_leaf_index += 1;
            current_root = new_root;
            i += 1;
        }

        save_data(denomination, next_leaf_index, current_root,
                  owner, oracle, nullifiers, roots, vk_data, tree_nodes, attestations);

        return ();
    }

    if (op == op::withdraw) {
        ;; ============= WITHDRAW =============
        int root = in_msg_body~load_uint(256);
        int nullifier = in_msg_body~load_uint(256);
        int ext_hash = in_msg_body~load_uint(256);

        ;; Check nullifier not spent
        (slice val, int found) = nullifiers.udict_get?(256, nullifier);
        throw_if(200, found);

        ;; Check root is known
        (slice rval, int rfound) = roots.udict_get?(256, root);
        throw_unless(201, rfound);

        ;; Compute public input hash: MiMC(root, nullifier, ext_hash)
        int pub_hash = mimc_hash3(root, nullifier, ext_hash);

        ;; Verify proof via oracle attestation
        throw_unless(202, verify_attestation(attestations, pub_hash));

        ;; Mark nullifier as spent
        nullifiers~udict_set(256, nullifier,
            begin_cell().store_uint(1, 1).end_cell().begin_parse());

        ;; Remove used attestation
        attestations~udict_delete?(256, pub_hash);

        ;; Transfer denomination to sender
        var msg = begin_cell()
            .store_uint(0x10, 6)
            .store_slice(sender)
            .store_coins(denomination)
            .store_uint(0, 107)
        .end_cell();
        send_raw_message(msg, 1);

        save_data(denomination, next_leaf_index, current_root,
                  owner, oracle, nullifiers, roots, vk_data, tree_nodes, attestations);
        return ();
    }

    if (op == op::withdraw_relayer) {
        ;; ============= WITHDRAW VIA RELAYER =============
        int root = in_msg_body~load_uint(256);
        int nullifier = in_msg_body~load_uint(256);
        int ext_hash = in_msg_body~load_uint(256);
        slice recipient = in_msg_body~load_msg_addr();
        int relayer_fee = in_msg_body~load_coins();

        throw_if(300, relayer_fee >= denomination);

        (slice val, int found) = nullifiers.udict_get?(256, nullifier);
        throw_if(301, found);
        (slice rval, int rfound) = roots.udict_get?(256, root);
        throw_unless(302, rfound);

        ;; Verify via oracle attestation
        int pub_hash = mimc_hash3(root, nullifier, ext_hash);
        throw_unless(303, verify_attestation(attestations, pub_hash));

        nullifiers~udict_set(256, nullifier,
            begin_cell().store_uint(1, 1).end_cell().begin_parse());

        attestations~udict_delete?(256, pub_hash);

        ;; Pay relayer
        if (relayer_fee > 0) {
            var relay_msg = begin_cell()
                .store_uint(0x10, 6)
                .store_slice(sender)
                .store_coins(relayer_fee)
                .store_uint(0, 107)
            .end_cell();
            send_raw_message(relay_msg, 1);
        }

        ;; Pay recipient
        var recip_msg = begin_cell()
            .store_uint(0x10, 6)
            .store_slice(recipient)
            .store_coins(denomination - relayer_fee)
            .store_uint(0, 107)
        .end_cell();
        send_raw_message(recip_msg, 1);

        save_data(denomination, next_leaf_index, current_root,
                  owner, oracle, nullifiers, roots, vk_data, tree_nodes, attestations);
        return ();
    }

    if (op == op::batch_withdraw) {
        ;; ============= BATCH WITHDRAW =============
        int count = in_msg_body~load_uint(8);
        throw_unless(700, count > 0);
        throw_unless(701, count <= 5);

        int i = 0;
        while (i < count) {
            int root = in_msg_body~load_uint(256);
            int nullifier = in_msg_body~load_uint(256);
            int ext_hash = in_msg_body~load_uint(256);

            ;; Check nullifier not spent
            (slice val, int found) = nullifiers.udict_get?(256, nullifier);
            throw_if(200, found);

            ;; Check root is known
            (slice rval, int rfound) = roots.udict_get?(256, root);
            throw_unless(201, rfound);

            ;; Compute public input hash and verify attestation
            int pub_hash = mimc_hash3(root, nullifier, ext_hash);
            throw_unless(202, verify_attestation(attestations, pub_hash));

            ;; Mark nullifier as spent
            nullifiers~udict_set(256, nullifier,
                begin_cell().store_uint(1, 1).end_cell().begin_parse());

            ;; Remove used attestation
            attestations~udict_delete?(256, pub_hash);

            i += 1;
        }

        ;; Transfer total denomination to sender
        var msg = begin_cell()
            .store_uint(0x10, 6)
            .store_slice(sender)
            .store_coins(denomination * count)
            .store_uint(0, 107)
        .end_cell();
        send_raw_message(msg, 1);

        save_data(denomination, next_leaf_index, current_root,
                  owner, oracle, nullifiers, roots, vk_data, tree_nodes, attestations);
        return ();
    }

    if (op == op::submit_proof_attestation) {
        ;; ============= ORACLE PROOF ATTESTATION =============
        ;; Only the trusted oracle can submit proof attestations.
        ;; The oracle verifies the Groth16 BN254 proof off-chain
        ;; and submits the public input hash as an attestation.
        throw_unless(500, equal_slices(sender, oracle));

        int pub_hash = in_msg_body~load_uint(256);

        ;; Store attestation
        attestations~udict_set(256, pub_hash,
            begin_cell().store_uint(1, 1).end_cell().begin_parse());

        save_data(denomination, next_leaf_index, current_root,
                  owner, oracle, nullifiers, roots, vk_data, tree_nodes, attestations);
        return ();
    }

    if (op == op::set_oracle) {
        ;; ============= SET ORACLE ADDRESS =============
        ;; Only owner can change the oracle
        throw_unless(600, equal_slices(sender, owner));

        slice new_oracle = in_msg_body~load_msg_addr();

        save_data(denomination, next_leaf_index, current_root,
                  owner, new_oracle, nullifiers, roots, vk_data, tree_nodes, attestations);
        return ();
    }

    throw(0xffff); ;; Unknown operation
}

;; =========================================================================
;;                       PROOF VERIFICATION
;; =========================================================================

;; Check if an oracle attestation exists for the given public input hash
int verify_attestation(cell attestations, int pub_hash) inline {
    (slice val, int found) = attestations.udict_get?(256, pub_hash);
    return found;
}

;; =========================================================================
;;                        GET METHODS
;; =========================================================================

int get_root() method_id {
    (_, _, int root, _, _, _, _, _, _, _) = load_data();
    return root;
}

int get_denomination() method_id {
    (int denom, _, _, _, _, _, _, _, _, _) = load_data();
    return denom;
}

int get_next_leaf_index() method_id {
    (_, int idx, _, _, _, _, _, _, _, _) = load_data();
    return idx;
}

int is_spent(int nullifier) method_id {
    (_, _, _, _, _, cell nullifiers, _, _, _, _) = load_data();
    (_, int found) = nullifiers.udict_get?(256, nullifier);
    return found;
}

int has_attestation(int pub_hash) method_id {
    (_, _, _, _, _, _, _, _, _, cell attestations) = load_data();
    (_, int found) = attestations.udict_get?(256, pub_hash);
    return found;
}

;; Compute MiMC hash of two values (for off-chain tree building)
int compute_mimc_hash(int a, int b) method_id {
    return mimc_hash(a, b);
}

;; Compute Merkle hash at a given level (for off-chain tree building)
int compute_merkle_hash(int level, int left, int right) method_id {
    return merkle_hash(level, left, right);
}
