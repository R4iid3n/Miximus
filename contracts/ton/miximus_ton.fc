;; Miximus TON Smart Contract (FunC)
;;
;; zkSNARK-based mixer for TON (Toncoin).
;; Written in FunC for the TON Virtual Machine (TVM).
;;
;; Supported: TON (native)
;;
;; TON's TVM is a stack-based VM with native support for:
;;   - 256-bit integers (and arbitrary precision)
;;   - Merkle proofs (via cell trees)
;;   - Hash functions (SHA256)
;;
;; MiMC Implementation:
;;   - x^7 exponent, 91 rounds, Miyaguchi-Preneel compression
;;   - Round constants hardcoded (TVM lacks native keccak256)
;;   - All arithmetic in BN254 scalar field
;;
;; Proof verification:
;;   - TVM lacks BN254 pairing precompiles
;;   - Uses oracle attestation pattern: trusted oracle submits proof validity
;;
;; Copyright 2024 Miximus Authors — GPL-3.0-or-later

#include "stdlib.fc";

;; =========================================================================
;;                           CONSTANTS
;; =========================================================================

const int TREE_DEPTH = 29;
const int MAX_LEAVES = 536870912; ;; 2^29
const int SCALAR_FIELD = 21888242871839275222246405745257275088548364400416034343698204186575808495617;
const int MIMC_ROUNDS = 91;

;; Operation codes
const int op::deposit = 0x1;
const int op::withdraw = 0x2;
const int op::withdraw_relayer = 0x3;
const int op::submit_proof_attestation = 0x4;
const int op::set_oracle = 0x5;
const int op::batch_deposit = 0x6;
const int op::batch_withdraw = 0x7;

