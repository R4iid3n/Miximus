# Miximus Waves Smart Contract (Ride v6)
#
# zkSNARK-based mixer for Waves.
# Written in Ride language for the Waves blockchain.
#
# MiMC & Merkle tree:
#   - Ride has limited compute budget for full MiMC on-chain
#   - Merkle root computed off-chain, verified on-chain via root tracking
#   - Off-chain uses: x^7 exponent, 91 rounds, Miyaguchi-Preneel, keccak256 hash chain
#   - 29 level-specific IVs for Merkle tree (stored here for reference)
#
# Proof verification:
#   - Waves natively supports groth16Verify for BN254!
#   - groth16Verify_1inputs(vk, proof, inputs) is a built-in function
#   - This enables REAL on-chain Groth16 BN254 verification
#   - The verifying key is stored on-chain as a binary blob
#
# Supported: WAVES (native)
#
# Copyright 2024 Miximus Authors — GPL-3.0-or-later

{-# STDLIB_VERSION 6 #-}
{-# CONTENT_TYPE DAPP #-}
{-# SCRIPT_TYPE ACCOUNT #-}

let TREE_DEPTH = 29
let MAX_LEAVES = 536870912  # 2^29

# =========================================================================
#                          STORAGE KEYS
# =========================================================================

func denominationKey() = "denomination"
func nextLeafIndexKey() = "next_leaf_index"
func currentRootKey() = "current_root"
func vkDataKey() = "vk_data"
func ownerKey() = "owner"
func nullifierKey(n: String) = "nullifier_" + n
func rootKey(r: String) = "root_" + r
func treeNodeKey(level: Int, index: Int) = "node_" + toString(level) + "_" + toString(index)

