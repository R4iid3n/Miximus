{
  "name": "miximus-multichain-evm",
  "version": "2.0.0",
  "description": "Multi-chain Miximus EVM deployment - zkSNARK mixer for all EVM chains",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:ethereum": "hardhat run deploy.js --network ethereum",
    "deploy:bsc": "hardhat run deploy.js --network bsc",
    "deploy:polygon": "hardhat run deploy.js --network polygon",
    "deploy:avalanche": "hardhat run deploy.js --network avalanche",
    "deploy:arbitrum": "hardhat run deploy.js --network arbitrum",
    "deploy:base": "hardhat run deploy.js --network base",
    "deploy:optimism": "hardhat run deploy.js --network optimism",
    "deploy:cronos": "hardhat run deploy.js --network cronos",
    "deploy:moonbeam": "hardhat run deploy.js --network moonbeam",
    "deploy:etc": "hardhat run deploy.js --network ethereum_classic",
    "deploy:all-testnets": "hardhat run deploy.js --network sepolia && hardhat run deploy.js --network bsc_testnet && hardhat run deploy.js --network polygon_mumbai && hardhat run deploy.js --network avalanche_fuji",
    "verify": "hardhat verify"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "dotenv": "^17.2.4",
    "hardhat": "^2.19.0",
    "hardhat-deploy": "^0.11.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.1",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  }
}
